generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  demoCapital         Float    @default(500)
  riskPerTradePercent Float    @default(1)
  maxOpenTrades       Int      @default(5)
  maxDailyLossPercent Float    @default(3)
  displayCurrency     String   @default("USD")
  beginnerMode        Boolean  @default(true)
  autoPaperTrading    Boolean  @default(true)
  realTradingEnabled  Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PaperAccount {
  id                 String           @id @default(cuid())
  userId             String           @unique
  currency           String           @default("EUR")
  startingBalance    Float            @default(500)
  cashBalance        Float            @default(500)
  availableCash      Float            @default(500)
  usedCapital        Float            @default(0)
  openPositionsValue Float            @default(0)
  unrealizedPnL      Float            @default(0)
  realizedPnL        Float            @default(0)
  totalEquity        Float            @default(500)
  totalReturnPercent Float            @default(0)
  dailyPnL           Float            @default(0)
  weeklyPnL          Float            @default(0)
  monthlyPnL         Float            @default(0)
  maxDrawdown        Float            @default(0)
  buyingPowerPaper   Float            @default(500)
  totalFeesSimulated Float            @default(0)
  totalSlippageSimulated Float        @default(0)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  positions          PaperPosition[]
  tradeEvents        PaperTradeEvent[]
  equitySnapshots    EquitySnapshot[]

  @@index([updatedAt])
}

model PaperPosition {
  id                   String             @id @default(cuid())
  accountId            String
  account              PaperAccount       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sourcePaperTradeId   String?            @unique
  assetType            String             @default("stock")
  ticker               String
  symbol               String
  assetName            String
  entryPrice           Float
  currentPrice         Float
  exitPrice            Float?
  quantity             Float
  positionValue        Float
  initialPositionValue Float
  unrealizedPnL        Float              @default(0)
  realizedPnL          Float              @default(0)
  pnlPercent           Float              @default(0)
  stopLoss             Float
  takeProfit           Float
  trailingStop         Float?
  strategyName         String             @default("Unclassified")
  entryReason          String
  exitReason           String?
  status               String             @default("Open")
  openedAt             DateTime           @default(now())
  closedAt             DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  events               PaperTradeEvent[]
  markers              TradeChartMarker[]

  @@index([accountId])
  @@index([assetType])
  @@index([ticker])
  @@index([symbol])
  @@index([status])
  @@index([openedAt])
}

model Stock {
  id                 String   @id @default(cuid())
  ticker             String   @unique
  companyName        String
  sector             String
  industry           String
  marketCap          Float
  price              Float
  previousClose      Float
  volume             Int
  avgVolume          Int
  relativeVolume     Float
  dailyChangePercent Float
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model MarketScan {
  id           String         @id @default(cuid())
  assetType    String         @default("stock")
  scanDate     DateTime       @default(now())
  market       String
  totalScanned Int
  createdAt    DateTime       @default(now())
  signals      MarketSignal[]

  @@index([assetType])
}

model MarketSignal {
  id                 String     @id @default(cuid())
  assetType          String     @default("stock")
  scanId             String
  scan               MarketScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  ticker             String
  signalType         String
  score              Int
  riskLevel          String
  decision           String
  explanation        String
  price              Float
  dailyChangePercent Float
  relativeVolume     Float
  scoreBreakdownJson String     @default("[]")
  checklistJson      String     @default("[]")
  strategyName       String     @default("Unclassified")
  strategyStatus     String     @default("NEW")
  researchQuality    String     @default("LIMITED")
  noTradeReasonsJson String     @default("[]")
  evidenceJson       String     @default("{}")
  strategyProofJson  String     @default("{}")
  createdAt          DateTime   @default(now())

  @@index([ticker])
  @@index([assetType])
  @@index([scanId])
}

model MarketSnapshot {
  id                 String   @id @default(cuid())
  assetType          String   @default("stock")
  ticker             String
  companyName        String
  sector             String
  price              Float
  previousClose      Float
  volume             Int
  avgVolume          Int
  relativeVolume     Float
  dailyChangePercent Float
  signalType         String
  score              Int
  riskLevel          String
  capturedAt         DateTime @default(now())

  @@index([ticker])
  @@index([assetType])
  @@index([capturedAt])
}

model ScannerJob {
  id          String    @id @default(cuid())
  name        String    @unique
  status      String    @default("Idle")
  cadence     String
  lastRunAt   DateTime?
  nextRunAt   DateTime?
  runCount    Int       @default(0)
  lastSummary String?
  lastError   String?
  updatedAt   DateTime  @updatedAt
  createdAt   DateTime  @default(now())
}

model AgentRun {
  id            String   @id @default(cuid())
  assetType     String   @default("stock")
  agentName     String
  jobName       String?
  status        String
  inputTicker   String?
  inputJson     String
  outputSummary String
  outputJson    String
  error         String?
  createdAt     DateTime @default(now())

  @@index([assetType])
  @@index([agentName])
  @@index([inputTicker])
  @@index([createdAt])
}

model ResearchReport {
  id               String   @id @default(cuid())
  assetType        String   @default("stock")
  ticker           String
  companyName      String
  summary          String
  whyDetected      String
  bullCase         String
  bearCase         String
  risks            String
  fundamentals     String
  valuationComment String
  technicalPicture String
  catalysts        String
  aiScore          Int
  confidence       Int
  riskLevel        String
  decision         String
  sourcesJson      String
  scoreBreakdownJson String   @default("[]")
  checklistJson      String   @default("[]")
  strategyName       String   @default("Unclassified")
  strategyStatus     String   @default("NEW")
  researchQuality    String   @default("LIMITED")
  noTradeReasonsJson String   @default("[]")
  evidenceJson       String   @default("{}")
  strategyProofJson  String   @default("{}")
  dataSource         String   @default("Unknown")
  catalystSource     String   @default("Unknown")
  priceDataSource    String   @default("Unknown")
  researchProvider   String   @default("TradePilot deterministic professional engine")
  aiProviderUsed     String   @default("none")
  confidenceQuality  String   @default("limited")
  limitationsJson    String   @default("[]")
  aiMode             String   @default("TECHNICAL_ONLY")
  createdAt        DateTime @default(now())

  @@index([ticker])
  @@index([assetType])
}

model AIPrediction {
  id               String    @id @default(cuid())
  assetType        String    @default("stock")
  ticker           String
  signalType       String
  sector           String
  predictedScore   Int
  confidence       Int
  decision         String
  riskLevel        String
  entryPrice       Float
  oneDayReturn     Float?
  sevenDayReturn   Float?
  thirtyDayReturn  Float?
  outcomeStatus    String    @default("Pending")
  checkedAt        DateTime?
  researchReportId String?
  createdAt        DateTime  @default(now())

  @@index([ticker])
  @@index([assetType])
  @@index([signalType])
  @@index([sector])
  @@index([outcomeStatus])
}

model DecisionScore {
  id             String   @id @default(cuid())
  assetType      String   @default("stock")
  ticker         String
  signalType     String
  sector         String
  baseScore      Int
  adjustedScore  Int
  confidence     Int
  decision       String
  riskLevel      String
  scoringJson    String
  createdAt      DateTime @default(now())

  @@index([ticker])
  @@index([assetType])
  @@index([createdAt])
}

model TradePlan {
  id              String       @id @default(cuid())
  assetType       String       @default("stock")
  ticker          String
  entryPrice      Float
  stopLoss        Float
  takeProfit      Float
  positionSize    Float
  quantity        Int
  maxLoss         Float
  riskRewardRatio Float
  reasoning       String
  status          String       @default("Draft")
  signalKey       String?
  analysisId      String?
  professionalJson String       @default("{}")
  strategyName     String       @default("Unclassified")
  strategyStatus   String       @default("NEW")
  researchQuality  String       @default("LIMITED")
  createdAt       DateTime     @default(now())
  paperTrades     PaperTrade[]

  @@index([ticker])
  @@index([assetType])
  @@index([analysisId])
  @@index([signalKey])
}

model PaperTrade {
  id                String    @id @default(cuid())
  assetType         String    @default("stock")
  ticker            String
  entryPrice        Float
  currentPrice      Float
  exitPrice         Float?
  quantity          Int
  positionSize      Float
  stopLoss          Float
  takeProfit        Float
  profitLoss        Float     @default(0)
  profitLossPercent Float     @default(0)
  entryFee         Float     @default(0)
  exitFee          Float     @default(0)
  entrySlippage    Float     @default(0)
  exitSlippage     Float     @default(0)
  executionModel   String    @default("legacy")
  status            String    @default("Open")
  openedAt          DateTime  @default(now())
  closedAt          DateTime?
  tradePlanId       String?
  signalKey         String?
  analysisId        String?
  tradePlan         TradePlan? @relation(fields: [tradePlanId], references: [id], onDelete: SetNull)
  events            PaperTradeEvent[]

  @@index([ticker])
  @@index([assetType])
  @@index([status])
  @@index([signalKey])
  @@index([analysisId])
}

model AIAnalysis {
  id                         String   @id @default(cuid())
  candidateId                String?
  tradeId                    String?
  symbol                     String
  provider                   String
  model                      String
  status                     String
  recommendation             String
  confidence                 Int
  reasoningJson              String
  risksJson                  String
  catalystsJson              String
  invalidationConditionsJson String
  sourceQuality              String
  inputSummary               String
  rawResponseReference       String?
  inputHash                  String
  fallbackUsed               Boolean  @default(false)
  technicalOnly              Boolean  @default(false)
  cached                     Boolean  @default(false)
  latencyMs                  Int      @default(0)
  estimatedCostUsd           Float    @default(0)
  errorCode                  String?
  createdAt                  DateTime @default(now())

  @@index([symbol])
  @@index([inputHash])
  @@index([createdAt])
  @@index([provider])
  @@index([tradeId])
}

model AIProviderHealth {
  provider      String    @id
  healthy       Boolean   @default(true)
  lastSuccessAt DateTime?
  lastFailureAt DateTime?
  failureCount  Int       @default(0)
  disabledUntil DateTime?
  lastErrorCode String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model WorkerLock {
  name        String    @id
  owner       String
  status      String    @default("Idle")
  heartbeatAt DateTime?
  lockedUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([lockedUntil])
  @@index([heartbeatAt])
}

model BrokerConnection {
  id                 String   @id @default(cuid())
  provider           String
  environment        String
  status             String
  accountNumber      String?
  currency           String?
  buyingPower        Float?
  cash               Float?
  portfolioValue     Float?
  isLive             Boolean  @default(false)
  liveTradingAllowed Boolean  @default(false)
  lastSyncAt         DateTime?
  lastError          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([provider, environment])
}

model BrokerOrder {
  id               String   @id @default(cuid())
  provider         String
  environment      String
  brokerOrderId    String?
  ticker           String
  side             String
  orderType        String
  timeInForce      String
  quantity         Int
  notional         Float?
  limitPrice       Float?
  stopPrice        Float?
  takeProfitPrice  Float?
  status           String
  source           String
  tradePlanId      String?
  paperTradeId     String?
  requestJson      String
  responseJson     String?
  error            String?
  realMoneyBlocked Boolean  @default(false)
  submittedAt      DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([ticker])
  @@index([provider, environment])
  @@index([status])
}

model PaperTradeEvent {
  id           String      @id @default(cuid())
  assetType    String      @default("stock")
  accountId    String?
  account      PaperAccount? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  positionId   String?
  position     PaperPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull)
  paperTradeId String?
  paperTrade   PaperTrade? @relation(fields: [paperTradeId], references: [id], onDelete: SetNull)
  ticker       String
  symbol       String?
  eventType    String
  price        Float?
  quantity     Float?
  positionValue Float?
  pnl          Float?
  pnlPercent   Float?
  profitLoss   Float?
  reason       String?
  strategyName String?
  candleTime   DateTime?
  message      String
  createdAt    DateTime    @default(now())

  @@index([accountId])
  @@index([positionId])
  @@index([ticker])
  @@index([symbol])
  @@index([assetType])
  @@index([eventType])
  @@index([createdAt])
}

model EquitySnapshot {
  id                 String       @id @default(cuid())
  accountId          String
  account            PaperAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  totalEquity        Float
  cashBalance        Float
  openPositionsValue Float
  unrealizedPnL      Float
  realizedPnL        Float
  drawdown           Float
  createdAt          DateTime     @default(now())

  @@index([accountId])
  @@index([createdAt])
}

model TradeChartMarker {
  id          String         @id @default(cuid())
  positionId  String?
  position    PaperPosition? @relation(fields: [positionId], references: [id], onDelete: SetNull)
  assetType   String         @default("stock")
  ticker      String
  symbol      String
  markerType  String
  price       Float
  time        DateTime
  label       String
  colorType   String
  reason      String?
  createdAt   DateTime       @default(now())

  @@index([positionId])
  @@index([assetType])
  @@index([ticker])
  @@index([symbol])
  @@index([time])
}

model WatchlistItem {
  id          String   @id @default(cuid())
  assetType   String   @default("stock")
  ticker      String   @unique
  companyName String
  score       Int
  riskLevel   String
  decision    String
  notes       String?
  createdAt   DateTime @default(now())

  @@index([assetType])
}

model JournalEntry {
  id          String   @id @default(cuid())
  ticker      String
  decision    String
  entryReason String
  exitReason  String?
  emotion     String
  mistake     String?
  lesson      String
  aiReview    String?
  result      String
  createdAt   DateTime @default(now())
}

model Alert {
  id          String   @id @default(cuid())
  assetType   String   @default("stock")
  ticker      String
  alertType   String
  targetPrice Float?
  message     String
  severity    String   @default("Info")
  active      Boolean  @default(true)
  readAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([ticker])
  @@index([assetType])
  @@index([alertType])
  @@index([active])
}

model StrategyPerformance {
  id              String   @id @default(cuid())
  scope           String
  scopeValue      String
  tradeCount      Int      @default(0)
  winRate         Float    @default(0)
  averageGain     Float    @default(0)
  averageLoss     Float    @default(0)
  profitFactor    Float    @default(0)
  maxDrawdown     Float    @default(0)
  bestSignalType  String?
  worstSignalType String?
  bestSector      String?
  worstSector     String?
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@unique([scope, scopeValue])
}

model LearningInsight {
  id         String   @id @default(cuid())
  assetType  String   @default("stock")
  title      String
  insight    String
  confidence Int
  category   String
  createdAt  DateTime @default(now())

  @@index([assetType])
  @@index([category])
  @@index([createdAt])
}

model RiskEvent {
  id          String   @id @default(cuid())
  assetType   String   @default("stock")
  ticker      String?
  rule        String
  severity    String
  blocked     Boolean  @default(false)
  message     String
  contextJson String
  createdAt   DateTime @default(now())

  @@index([ticker])
  @@index([assetType])
  @@index([rule])
  @@index([blocked])
}

model BacktestResult {
  id              String   @id @default(cuid())
  assetType       String   @default("stock")
  strategyName    String
  startDate       DateTime
  endDate         DateTime
  totalTrades     Int
  winRate         Float
  profitFactor    Float
  maxDrawdown     Float
  summary         String
  createdAt       DateTime @default(now())

  @@index([strategyName])
  @@index([assetType])
}

model TradingControl {
  id                String   @id @default("global")
  newEntriesEnabled Boolean  @default(true)
  emergencyHalt     Boolean  @default(false)
  reason            String?
  haltedAt          DateTime?
  resumedAt         DateTime?
  updatedAt         DateTime @updatedAt
  createdAt         DateTime @default(now())
}

model MarketRegimeSnapshot {
  id                     String   @id @default(cuid())
  assetType              String   @default("stock")
  regime                 String
  longScore              Int
  confidence             Int
  allowLongBreakouts     Boolean
  positionSizeMultiplier Float
  metricsJson            String
  warningsJson           String
  summary                String
  capturedAt             DateTime @default(now())

  @@index([assetType])
  @@index([regime])
  @@index([capturedAt])
}

model ProfessionalDecisionRecord {
  id                     String   @id @default(cuid())
  assetType              String   @default("stock")
  ticker                 String
  strategyName           String
  strategyVersion        String
  decision               String
  committeeScore         Int
  confidence             Int
  positionSizeMultiplier Float    @default(0)
  signalScore            Int
  strategyScore          Int
  marketRegime           String
  riskState              String
  executionGrade         String
  riskRewardRatio        Float
  signalKey              String?
  tradePlanId            String?
  paperTradeId           String?
  shadowOnly             Boolean  @default(false)
  votesJson              String
  reasonsJson            String
  contextJson            String
  createdAt              DateTime @default(now())

  @@index([assetType])
  @@index([ticker])
  @@index([decision])
  @@index([tradePlanId])
  @@index([paperTradeId])
  @@index([createdAt])
}

model ExecutionSimulation {
  id                 String   @id @default(cuid())
  paperTradeId       String?
  assetType          String   @default("stock")
  ticker             String
  side               String
  requestedPrice     Float
  requestedQuantity  Int
  filledQuantity     Int
  partialFill        Boolean  @default(false)
  fillPrice          Float
  estimatedBid       Float
  estimatedAsk       Float
  spreadBps          Float
  slippageBps        Float
  totalExecutionBps  Float
  slippageAmount     Float
  fee                Float
  latencyMs          Int
  participationRate  Float
  qualityGrade       String
  modelVersion       String
  warningsJson       String
  createdAt          DateTime @default(now())

  @@index([paperTradeId])
  @@index([assetType])
  @@index([ticker])
  @@index([side])
  @@index([createdAt])
}

model ShadowTrade {
  id                  String    @id @default(cuid())
  assetType           String    @default("stock")
  ticker              String
  strategyName        String
  strategyVersion     String
  direction           String    @default("LONG")
  entryPrice          Float
  currentPrice        Float
  exitPrice           Float?
  stopLoss            Float
  takeProfit          Float
  quantity            Int       @default(1)
  profitLoss          Float     @default(0)
  profitLossPercent   Float     @default(0)
  status              String    @default("Open")
  committeeScore      Int
  marketRegime        String
  sourceDecisionId    String?
  reason              String
  contextJson         String
  openedAt            DateTime  @default(now())
  closedAt            DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([assetType])
  @@index([ticker])
  @@index([strategyName])
  @@index([status])
  @@index([openedAt])
}

